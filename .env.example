# ── Gmail OAuth (免费) ─────────────────────────────────────────────────────────
# 1. console.cloud.google.com → 新建项目 → 启用 Gmail API
# 2. 创建 OAuth 2.0 客户端 ID (Web 应用)
# 3. 授权重定向 URI: http://localhost:3001/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# ── AI 分类器 — 填一个就够了，按优先级自动选择 ──────────────────────────────────

# 🥇 智谱 GLM-4-Flash【推荐，完全免费，国内注册最快】
# 注册: open.bigmodel.cn → API密钥
ZHIPU_API_KEY=

# 🥈 阿里云 Qwen-Turbo【免费额度，国内访问稳定】
# 注册: dashscope.aliyun.com → API-KEY管理
QWEN_API_KEY=

# 🥉 DeepSeek【超便宜，注册送额度】
# 注册: platform.deepseek.com → API keys
DEEPSEEK_API_KEY=

# 境外免费选项
# Groq (Llama 3.3 70b): console.groq.com
GROQ_API_KEY=
# Google Gemini Flash: aistudio.google.com
GOOGLE_AI_KEY=
# Anthropic Claude (付费)
ANTHROPIC_API_KEY=

# ── 服务器 ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5174
